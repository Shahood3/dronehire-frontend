# DroneHire - Environment Configuration

# API Configuration
# REACT_APP_API_URL=http://127.0.0.1:8000
# REACT_APP_API_URL=https://your-production-backend.com
REACT_APP_API_URL=http://localhost:8080/api

# Environment
REACT_APP_ENVIRONMENT=development
# REACT_APP_ENVIRONMENT=production

# App Info
REACT_APP_APP_NAME=DroneHire
REACT_APP_VERSION=1.0.0

# Build Configuration
GENERATE_SOURCEMAP=false

# Optional: JWT Token Expiry (in seconds)
# REACT_APP_TOKEN_EXPIRY=86400

# Optional: File Upload Size Limit (in MB)
# REACT_APP_MAX_UPLOAD_SIZE=10